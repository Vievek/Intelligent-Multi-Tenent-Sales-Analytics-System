{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": {
    "source": "functions",
    "predeploy": [
      "npm --prefix functions run build"
    ],
    "runtime": "nodejs20"
  },
  "hosting": {
    "source": "frontend",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": [
    {
      "name": "receiveTelegramMessage",
      "entryPoint": "receiveTelegramMessage",
      "runtime": "nodejs20",
      "environmentVariables": {
        "PUBSUB_TOPIC": "sales-messages"
      }
    },
    {
      "name": "processSalesMessage",
      "entryPoint": "processSalesMessage",
      "runtime": "nodejs20",
      "eventTrigger": {
        "eventType": "google.cloud.pubsub.topic.v1.messagePublished",
        "resource": "projects/${PROJECT_ID}/topics/sales-messages"
      },
      "environmentVariables": {}
    }
  ]
}
